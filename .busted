return {
	-- Default (plain `busted` with no args) runs unit tests only.
	default = {
		lpath = "./plugin/?.lua;./spec/?.lua",
		pattern = "_spec",
		ROOT = { "spec" },
		exclude_pattern = "integration",
	},
	unit = {
		lpath = "./plugin/?.lua;./spec/?.lua",
		pattern = "_spec",
		ROOT = { "spec" },
		exclude_pattern = "integration",
	},
	integration = {
		lpath = "./plugin/?.lua;./spec/?.lua",
		pattern = "_spec",
		ROOT = { "spec/integration" },
	},
}
